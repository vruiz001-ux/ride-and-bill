generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

// ─── NextAuth Models ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App Models ───────────────────────────────────────────────────────────────

model User {
  id                   String               @id @default(cuid())
  name                 String?
  email                String?              @unique
  emailVerified        DateTime?
  image                String?
  hashedPassword       String?
  role                 String               @default("user")
  companyName          String?
  companyAddress       String?
  vatId                String?
  timezone             String               @default("UTC")
  defaultCurrency      String               @default("EUR")
  defaultMarkupPercent Float                @default(5)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  accounts             Account[]
  sessions             Session[]
  emailAccounts        ConnectedEmailAccount[]
  receipts             Receipt[]
  billingEntities      BillingEntity[]
  invoiceBatches       InvoiceBatch[]
  exportJobs           ExportJob[]
  statements           Statement[]
  auditLogs            AuditLog[]
  passwordResetTokens  PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  workspaceMembers     WorkspaceMember[]
}

model Workspace {
  id                String   @id @default(cuid())
  name              String
  ownerUserId       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  members           WorkspaceMember[]
  subscription      Subscription?
  receipts          Receipt[]
  emailAccounts     ConnectedEmailAccount[]
  billingEntities   BillingEntity[]
  invoiceBatches    InvoiceBatch[]
  exportJobs        ExportJob[]
  statements        Statement[]
  auditLogs         AuditLog[]
  usageCounters     UsageCounter[]
  usageEvents       UsageEvent[]
  syncRuns          SyncRun[]

  @@index([ownerUserId])
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("member")
  invitedAt   DateTime @default(now())
  joinedAt    DateTime @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Subscription {
  id                  String   @id @default(cuid())
  workspaceId         String   @unique
  plan                String   @default("free")
  status              String   @default("active")
  billingCycleAnchor  DateTime @default(now())
  currentPeriodStart  DateTime @default(now())
  currentPeriodEnd    DateTime
  stripeCustomerId    String?
  stripeSubscriptionId String?
  cancelAtPeriodEnd   Boolean  @default(false)
  trialEndsAt         DateTime?
  customSeats         Int?
  customInboxes       Int?
  customReceipts      Int?
  customRetentionDays Int?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  workspace           Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([status])
}

model UsageCounter {
  id          String   @id @default(cuid())
  workspaceId String
  metric      String
  periodStart DateTime
  periodEnd   DateTime
  count       Int      @default(0)
  updatedAt   DateTime @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, metric, periodStart])
  @@index([workspaceId, metric])
}

model UsageEvent {
  id          String   @id @default(cuid())
  workspaceId String
  metric      String
  delta       Int      @default(1)
  receiptId   String?
  details     String?
  createdAt   DateTime @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, metric, createdAt])
}

model SyncRun {
  id              String   @id @default(cuid())
  workspaceId     String
  emailAccountId  String
  status          String   @default("running")
  totalScanned    Int      @default(0)
  newReceipts     Int      @default(0)
  skipped         Int      @default(0)
  errors          Int      @default(0)
  errorMessage    String?
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([emailAccountId])
}

model ConnectedEmailAccount {
  id            String   @id @default(cuid())
  userId        String
  workspaceId   String?
  provider      String
  email         String
  accessToken   String?
  refreshToken  String?
  status        String   @default("active")
  lastSyncAt    DateTime?
  syncStatus    String   @default("idle")
  totalImported Int      @default(0)
  connectedAt   DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace     Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([userId, email])
  @@index([userId])
  @@index([workspaceId])
}

model Receipt {
  id                   String   @id @default(cuid())
  userId               String
  workspaceId          String?
  provider             String
  sourceEmailAccountId String
  sourceMessageId      String   @unique
  receiptExternalId    String?
  tripDate             DateTime
  importDate           DateTime @default(now())
  country              String
  countryCode          String
  city                 String
  pickupLocation       String?
  dropoffLocation      String?
  amountTotal          Float
  amountTax            Float?
  currency             String
  paymentMethodMasked  String?
  businessPurpose      String?
  notes                String?
  tags                 String   @default("")
  rawEmailSubject      String
  rawEmailSender       String
  originalFileUrl      String?
  normalizedPdfUrl     String?
  parserVersion        String
  parsingConfidence    Float
  status               String   @default("parsed")
  originalAmount       Float
  originalCurrency     String
  fxRate               Float?
  fxRateDate           String?
  fxSource             String?
  markupPercent        Float    @default(5)
  convertedAmount      Float?
  convertedCurrency    String?
  invoiceAmount        Float?
  invoiceCurrency      String?
  billingEntityId      String?
  conversionStatus     String   @default("pending")
  fallbackRateUsed     Boolean  @default(false)
  isRefunded           Boolean  @default(false)
  refundAmount         Float?
  netInvoiceAmount     Float?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace            Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  billingEntity        BillingEntity? @relation(fields: [billingEntityId], references: [id])
  files                ReceiptFile[]
  statementReceipts    StatementReceipt[]

  @@index([userId, tripDate])
  @@index([userId, provider])
  @@index([userId, country])
  @@index([workspaceId, tripDate])
  @@index([workspaceId])
  @@index([billingEntityId])
}

model BillingEntity {
  id                       String   @id @default(cuid())
  userId                   String
  workspaceId              String?
  legalName                String
  billingAddress           String
  vatOrTaxId               String?
  contactEmail             String?
  preferredInvoiceCurrency String   @default("EUR")
  defaultMarkupPercent     Float    @default(5)
  notes                    String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace                Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  receipts                 Receipt[]
  invoiceBatches           InvoiceBatch[]

  @@index([userId])
  @@index([workspaceId])
}

model InvoiceBatch {
  id                String   @id @default(cuid())
  userId            String
  workspaceId       String?
  billingEntityId   String
  billingEntityName String
  invoiceCurrency   String
  markupPercent     Float
  subtotalOriginal  Float
  subtotalConverted Float
  markupAmount      Float
  totalInvoice      Float
  receiptCount      Int
  status            String   @default("draft")
  exportFileUrl     String?
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace         Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  billingEntity     BillingEntity @relation(fields: [billingEntityId], references: [id])

  @@index([userId])
  @@index([workspaceId])
  @@index([billingEntityId])
}

model ExportJob {
  id           String   @id @default(cuid())
  userId       String
  workspaceId  String?
  format       String
  status       String   @default("pending")
  filters      String   @default("{}")
  fileUrl      String?
  receiptCount Int      @default(0)
  createdAt    DateTime @default(now())
  completedAt  DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([workspaceId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  email     String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

// ─── Receipt Files ────────────────────────────────────────────────────────────

model ReceiptFile {
  id        String   @id @default(cuid())
  receiptId String
  filename  String
  mimeType  String
  sizeBytes Int
  hash      String
  data      String   // base64-encoded file content
  source    String   @default("email_attachment") // email_attachment | manual_upload | generated
  createdAt DateTime @default(now())
  receipt   Receipt  @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@unique([hash, receiptId])
  @@index([receiptId])
}

// ─── Statements ───────────────────────────────────────────────────────────────

model Statement {
  id                  String   @id @default(cuid())
  userId              String
  workspaceId         String?
  title               String
  periodStart         DateTime
  periodEnd           DateTime
  filtersJson         String   @default("{}")
  totalReceipts       Int      @default(0)
  totalAmount         Float    @default(0)
  totalAmountCurrency String   @default("EUR")
  outputCurrency      String   @default("EUR")
  applyMarkup         Boolean  @default(false)
  markupPercent       Float    @default(0)
  totalWithMarkup     Float?
  status              String   @default("generated")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace           Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  statementReceipts   StatementReceipt[]

  @@index([workspaceId, createdAt])
  @@index([userId])
}

model StatementReceipt {
  id          String    @id @default(cuid())
  statementId String
  receiptId   String
  statement   Statement @relation(fields: [statementId], references: [id], onDelete: Cascade)
  receipt     Receipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)

  @@unique([statementId, receiptId])
  @@index([statementId])
  @@index([receiptId])
}

// ─── Audit Logs ───────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String?
  userId      String
  action      String
  entityType  String
  entityId    String
  details     String?
  ipAddress   String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@index([workspaceId, createdAt])
  @@index([entityType, entityId])
}
